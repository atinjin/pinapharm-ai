generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pharmacist {
  id        Int       @id @default(autoincrement())
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            Int      @id @default(autoincrement())
  pharmacist    Pharmacist @relation(fields: [pharmacistId], references: [id])
  pharmacistId  Int
  name          String
  brand         String?
  description   String?
  price         Int
  ingredients   String?
  form          String?   // 제형: 정/캡슐/액상/분말/스틱/젤리 등
  doseAmount    Float?    // 용량 수치 (예: 300)
  doseUnit      String?   // 용량 단위 (mg/g/mL/IU 등)
  ingredientsStructured String? // JSON [{name, amount, unit}] (선택)
  conditionTags String    @default("[]")
  imageUrl      String?
  stock         Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  recommendations Recommendation[]
  orders          Order[]
}

model Consultation {
  id        Int       @id @default(autoincrement())
  sessionId String
  messages  Message[]
  recommendations Recommendation[]
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerId      Int?
  createdAt DateTime  @default(now())
}

model Message {
  id             Int          @id @default(autoincrement())
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  consultationId Int
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

model Recommendation {
  id             Int          @id @default(autoincrement())
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  consultationId Int
  product        Product      @relation(fields: [productId], references: [id])
  productId      Int
  reason         String?
  createdAt      DateTime     @default(now())
}

model Order {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int      @default(1)
  status    String   @default("created")
  createdAt DateTime @default(now())
}

model Customer {
  id            Int            @id @default(autoincrement())
  identities    Identity[]
  healthProfile HealthProfile?
  consultations Consultation[]
  createdAt     DateTime       @default(now())
}

model Identity {
  id                Int      @id @default(autoincrement())
  provider          String
  providerAccountId String
  customer          Customer @relation(fields: [customerId], references: [id])
  customerId        Int
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([customerId])
}

model AgentSetting {
  key       String   @id // persona | system_prompt | emergency_message | triage_prompt
  value     String
  updatedAt DateTime @updatedAt
}

model ConsultationSkill {
  id          Int      @id @default(autoincrement())
  name        String   @unique // kebab-case slug
  description String // 한 줄 — 언제 쓰는지(매칭용)
  body        String // markdown 상담 절차 본문
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeDocument {
  id         Int              @id @default(autoincrement())
  category   String           @default("general") // ingredient | reference | note 등
  title      String
  body       String // 원본 전체 텍스트
  source     String           @default("{}") // JSON: url/author/date/출처
  reviewedAt DateTime? // null = 검수 필요
  chunks     KnowledgeChunk[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model KnowledgeChunk {
  id             Int                @id @default(autoincrement())
  kind           String // "product" | "knowledge"
  refId          String? // product: productId
  document       KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId     Int? // null = 제품 청크
  chunkIndex     Int                @default(0)
  title          String
  text           String
  metadata       String             @default("{}")
  embedding      Bytes
  model          String
  embeddingStale Boolean            @default(false)
  updatedAt      DateTime           @updatedAt

  @@index([kind])
  @@index([documentId])
}

model HealthProfile {
  id          Int      @id @default(autoincrement())
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  Int      @unique
  ageBand     String?
  sex         String?
  conditions  String   @default("[]")
  medications String   @default("[]")
  allergies   String   @default("[]")
  pregnancy   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
